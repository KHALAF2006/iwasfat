      "type": "string",
      "description": "\u0648\u0635\u0641 \u0627\u0644\u0645\u0634\u0631\u0648\u0628"
    },
    "category": {
      "type": "string",
      "enum": [
        "hot",
        "cold",
        "juice",
        "healthy",
        "forbidden"

    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "false \u0644\u0644\u0645\u0634\u0631\u0648\u0628\u0627\u062a \u0627\u0644\u0645\u0645\u0646\u0648\u0639\u0629"
